<Layouts.app flash={@flash} current_scope={@current_scope}>
  <:toolbar>
    <div class="flex items-center justify-between px-4 py-2 bg-cm-surface sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 min-w-0">
        <.breadcrumb
          items={[
            %{
              label: @current_scope.organization.name,
              navigate: ~p"/org/#{@current_scope.organization.id}"
            },
            %{
              label: @family.name,
              navigate: ~p"/org/#{@current_scope.organization.id}/families/#{@family.id}"
            },
            %{
              label: @vault.name,
              navigate:
                ~p"/org/#{@current_scope.organization.id}/families/#{@family.id}/vaults/#{@vault.id}"
            }
          ]}
          current={@memory.name}
          {test_id("memory-show-name")}
        />
      </div>
      <.link
        navigate={
          ~p"/org/#{@current_scope.organization.id}/families/#{@family.id}/vaults/#{@vault.id}/memories/#{@memory.id}/edit"
        }
        class="inline-flex items-center gap-1.5 bg-cm-surface text-cm-black rounded-cm border-2 border-cm-black px-3 py-1.5 font-cm-mono text-[10px] font-bold uppercase tracking-wider hover:bg-cm-surface/80 transition-colors"
        {test_id("memory-edit-btn")}
      >
        <.icon name="hero-pencil" class="size-4" /> {gettext("Edit")}
      </.link>
    </div>
  </:toolbar>

  <div class="px-4 py-6 sm:px-6 lg:px-8 max-w-3xl mx-auto">
    <%!-- Cover photo --%>
    <%= if @memory.cover_photo do %>
      <div class="aspect-video overflow-hidden rounded-cm mb-6 bg-cm-surface">
        <img
          src={
            Ancestry.Uploaders.Photo.url({@memory.cover_photo.image, @memory.cover_photo}, :large)
          }
          alt={@memory.name}
          class="w-full h-full object-cover"
        />
      </div>
    <% end %>

    <%!-- Rendered content --%>
    <div
      class="prose prose-sm max-w-none text-cm-black font-cm-body trix-content"
      {test_id("memory-show-content")}
    >
      {Phoenix.HTML.raw(@rendered_content)}
    </div>

    <%!-- Metadata --%>
    <div class="mt-8 pt-4 border-t border-cm-border/20">
      <p class="font-cm-mono text-[10px] text-cm-text-muted uppercase tracking-wider">
        Created {Calendar.strftime(@memory.inserted_at, "%B %d, %Y")}
      </p>
    </div>
  </div>
</Layouts.app>
