<Layouts.print flash={@flash}>
  <h1 class="text-2xl font-bold text-black text-center mb-6">
    {@family.name}
  </h1>

  <%= if @tree do %>
    <div id="print-page" phx-hook="AutoPrint">
      <.print_tree tree={@tree} />
    </div>
  <% else %>
    <p class="text-center text-gray-500">
      {gettext("No tree to display")}
    </p>
  <% end %>
</Layouts.print>
