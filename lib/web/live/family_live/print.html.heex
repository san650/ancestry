<Layouts.print flash={@flash}>
  <h1 class="text-2xl font-cm-display font-bold text-cm-black text-center mb-6 uppercase tracking-wider">
    {@family.name}
  </h1>

  <%= if @tree do %>
    <div id="print-page" phx-hook="AutoPrint">
      <.print_tree tree={@tree} />
    </div>
  <% else %>
    <p class="text-center font-cm-body text-cm-text-muted">
      {gettext("No tree to display")}
    </p>
  <% end %>
</Layouts.print>
